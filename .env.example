# ---- Cloud burst model (Cerebras) ----------------------------------------
# Add EVERY teammate's key, comma-separated. Ferry round-robins across them so
# we can fan the backlog out wider than a single key's 100 RPM limit.
CEREBRAS_API_KEYS=csk-xxxx,csk-yyyy,csk-zzzz
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# gpt-oss-120b for now; flip to gemma-4-31b once your key has Gemma 4 preview access.
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_MAX_TOKENS=1024
# none | low | medium | high  (reasoning is off by default on Gemma 4)
CEREBRAS_REASONING_EFFORT=none

# ---- Local edge model (Ollama) -------------------------------------------
LOCAL_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://localhost:11434/v1

# ---- Web search tool (Exa) — read by config.py for Track 1 sub-agents ------
# Get a key at exa.ai (or from Ethan). Leave blank if not doing Track 1 yet.
EXA_API_KEY=

# ---- Code execution tool (E2B) — sandboxed code + file creation -----------
# Get a key at e2b.dev. Leave blank if not doing Track 1 yet.
E2B_API_KEY=

# ---- Router: heuristic | llm | always_cloud | always_local ----------------
ROUTER_MODE=heuristic
ROUTER_LENGTH_THRESHOLD=280

# ---- Connectivity watcher -------------------------------------------------
WATCHER_INTERVAL=2.5
WATCHER_PROBE_URL=https://api.cerebras.ai/v1/models

# ---- Burst drainer --------------------------------------------------------
DRAIN_CONCURRENCY=24
DRAIN_POLL_INTERVAL=1.0
MAX_ATTEMPTS=3

# ---- Storage --------------------------------------------------------------
DB_PATH=./data/ferry.db
