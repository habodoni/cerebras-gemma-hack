# Ferry config for the JETSON HUB deployment.
# Ferry runs ON the Jetson, so its local backend is the Jetson's own Ollama.
# Copy to `.env` on the Jetson:  cp .env.jetson.example .env

# ---- Local brain ----
# Default: Liquid LFM2.5 on the Jetson's native Ollama.
LOCAL_MODEL=LiquidAI/lfm2.5-1.2b-instruct
OLLAMA_BASE_URL=http://localhost:11434/v1
# Bonsai 27B (1-bit) alternative — installed by scripts/jetson_bonsai_setup.sh,
# which serves it via the PrismML llama.cpp fork on :11435 (Ollama can't load it).
# The script flips the two values below, sets LOCAL_MAX_TOKENS=400 and
# LOCAL_TIMEOUT_SECONDS=180, and pins EXTRA_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# so the picker extras stay on real Ollama:
# LOCAL_MODEL=1-bit-Bonsai-27B
# OLLAMA_BASE_URL=http://127.0.0.1:11435/v1

# ---- Model picker ----
# Hide the "ferry" auto-routing meta-model from the picker: the list then shows
# only the real models (local + extras). Requests naming "ferry" still route.
EXPOSE_ROUTER_MODEL=false

# ---- Extra picker models (comma-separated) ----
# Shown in Open WebUI next to "ferry"; picking one bypasses the router and talks
# to it directly. EXTRA_LOCAL_BASE_URL is where they live (defaults to
# OLLAMA_BASE_URL — set it to real Ollama when the main model moves to :11435).
# Liquid only: nemotron-3-nano:4b needs ~3.4 GB and can't fit beside a resident
# Bonsai on the 8 GB board (add it back only if you revert Bonsai).
EXTRA_LOCAL_MODELS=LiquidAI/lfm2.5-1.2b-instruct
# EXTRA_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# EXTRA_LOCAL_MAX_TOKENS=2048
LOCAL_MAX_TOKENS=64
LOCAL_TEMPERATURE=0.2
LOCAL_TIMEOUT_SECONDS=45
LOCAL_CONTEXT_MESSAGES=4
LOCAL_CONTEXT_CHARS=2400

# ---- Web search tool (Exa) — read by config.py for Track 1 sub-agents ----
EXA_API_KEY=

# ---- Code execution tool (E2B) — sandboxed code + file creation ----
E2B_API_KEY=
E2B_FILE_ROOTS=/home/user,/mnt/data
E2B_FILE_LIST_DEPTH=6
E2B_MAX_FILES=20
E2B_MAX_FILE_BYTES=10485760

# ---- Cloud burst (Cerebras) — drained over the Jetson's uplink ----
# Add every teammate's key (comma-separated) to widen the parallel window.
CEREBRAS_API_KEYS=csk-xxxx,csk-yyyy
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Gemma 4 is the central cloud model for every burst. Keys need Gemma 4
# preview access; set gpt-oss-120b manually only if a key lacks that access.
CEREBRAS_MODEL=gemma-4-31b
# Keep generous — reasoning consumes output tokens; must be <= the model's 131k ctx.
CEREBRAS_MAX_TOKENS=8192
# Voice/Hands global effort (tool loops + final answer). none | low | medium | high.
CEREBRAS_REASONING_EFFORT=none
# Brain steps (multiverse planner + synthesis) reason at this effort.
CEREBRAS_THINK_EFFORT=medium

# ---- Router: heuristic | llm | always_cloud | always_local ----
ROUTER_MODE=heuristic
ROUTER_LENGTH_THRESHOLD=280

# ---- Connectivity watcher: probes the Jetson's uplink ----
WATCHER_INTERVAL=2.5
WATCHER_PROBE_URL=https://api.cerebras.ai/v1/models

# ---- Burst drainer ----
DRAIN_CONCURRENCY=24
DRAIN_POLL_INTERVAL=1.0
MAX_ATTEMPTS=3

# ---- Storage ----
DB_PATH=./data/ferry.db
GENERATED_FILES_DIR=./data/generated
PUBLIC_BASE_URL=http://localhost:8080

# ---- Notifications: ping on queue + on return ----
# The Jetson is headless, so push to your phone via ntfy: install the ntfy app,
# subscribe to NTFY_TOPIC, and you get a buzz when a prompt queues and when its
# answer bursts back — even with the app closed.
NOTIFY_MODE=ntfy
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=ferry-CHANGE-ME-to-something-unguessable
