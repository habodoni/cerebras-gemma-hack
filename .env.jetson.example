# Ferry config for the JETSON HUB deployment.
# Ferry runs ON the Jetson, so its local backend is the Jetson's own Ollama.
# Copy to `.env` on the Jetson:  cp .env.jetson.example .env

# ---- Local brain: Liquid LFM2.5 on the Jetson's native Ollama ----
LOCAL_MODEL=bcluzel/LFM2.5-1.2B-Instruct:Q4_K_M
OLLAMA_BASE_URL=http://localhost:11434/v1

# ---- Web search tool (Exa) — read by config.py for Track 1 sub-agents ----
EXA_API_KEY=

# ---- Cloud burst (Cerebras) — drained over the Jetson's uplink ----
# Add every teammate's key (comma-separated) to widen the parallel window.
CEREBRAS_API_KEYS=csk-xxxx,csk-yyyy
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# gpt-oss-120b until your key has Gemma 4 preview access; flip to gemma-4-31b then.
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_MAX_TOKENS=1024
CEREBRAS_REASONING_EFFORT=none

# ---- Router: heuristic | llm | always_cloud | always_local ----
ROUTER_MODE=heuristic
ROUTER_LENGTH_THRESHOLD=280

# ---- Connectivity watcher: probes the Jetson's uplink ----
WATCHER_INTERVAL=2.5
WATCHER_PROBE_URL=https://api.cerebras.ai/v1/models

# ---- Burst drainer ----
DRAIN_CONCURRENCY=24
DRAIN_POLL_INTERVAL=1.0
MAX_ATTEMPTS=3

# ---- Storage ----
DB_PATH=./data/ferry.db
